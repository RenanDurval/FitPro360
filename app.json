{
  "expo": {
    "name": "FitPro360",
    "slug": "fitpro360",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fitpro360",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitpro360.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FitPro360 precisa da sua localização para rastrear atividades e encontrar locais próximos.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Usado para rastrear suas corridas e atividades em segundo plano.",
        "NSBluetoothAlwaysUsageDescription": "Usado para conectar a relógios e dispositivos de monitoramento de saúde.",
        "NSMotionUsageDescription": "Usado para contar seus passos e rastrear atividade física."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fitpro360.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACTIVITY_RECOGNITION",
        "BODY_SENSORS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FitPro360 rastreia suas atividades para calcular distância e calorias."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "FitPro360 usa sensores do dispositivo para contar passos e monitorar atividades."
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca097bed-e3a2-4b93-8333-0ff43456dd5e"
      }
    },
    "owner": "renandhurval"
  }
}
