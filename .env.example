# ============================================
# FitPro360 - Variáveis de Ambiente
# ============================================

# IMPORTANTE: Nunca comite o arquivo .env contendo chaves reais.
# Copie este arquivo para .env.local ou .env e preencha as variáveis.

# API Keys para Integração de Mapas e Rotas (usado futuramente pelo expo-location)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# API Key e Configurações de Backend / Auth (Supabase ou Firebase, se ativado na Fase 6)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Configurações de ambiente de build
NODE_ENV=development
